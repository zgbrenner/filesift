{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FileSift",
  "version": "0.1.2",
  "identifier": "com.filesift.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FileSift",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../python/analyzer.py", "../python/models.py", "../python/cli.py"],
    "externalBin": ["binaries/filesift-sidecar"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/zgbrenner/filesift/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBMTZCMzdFNEJEMEE0RUUKUldUdXBOQkxmck1XS2lreDNRVFgyaHp4VytDTjhDMUJ0NndWU3hoLzI1aFlyVWpqV1Y4ZElxSVAK"
    }
  }
}
